{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "ScholarMe API",
    "description": "Internal and external APIs for ScholarMe"
  },
  "servers": [
    {
      "url": "https://scholarme.vercel.app"
    }
  ],
  "components": {
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/api/health": {
      "get": {
        "description": "Check system health and database connectivity",
        "responses": {
          "200": {
            "description": "Object with health status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string"
                    },
                    "build": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable"
          }
        }
      }
    }
  }
}