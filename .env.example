# ScholarMe — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.

# -- Supabase -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
TEST_SUPABASE_URL=http://localhost:54321
TEST_SUPABASE_ANON_KEY=test-anon-key
TEST_SUPABASE_SERVICE_ROLE_KEY=test-service-key

# -- App -----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- AI Services ---------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
DOCUMENT_AI_PROCESSOR_ID=your-doc-ai-processor-id
OPENAI_API_KEY=your-openai-api-key

# -- Integrations --------------------------------------------------------------
DISCORD_WEBHOOK_URL=your-discord-webhook
RESEND_API_KEY=your-resend-key
STRIPE_SECRET_KEY=your-stripe-secret
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
CARD_LOGIN_SECRET=your-card-login-secret

